{
  "name": "@uluops/agent-metrics",
  "version": "0.1.0",
  "type": "module",
  "description": "Extract accurate metrics from Claude Code agent session files",
  "repository": {
    "type": "git",
    "url": "https://github.com/Uluops/-uluops-agent-metrics.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-metrics": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run clean && tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test 'dist/*.test.js' 'dist/**/*.test.js'",
    "test:coverage": "tsc -p tsconfig.test.json && node --test --experimental-test-coverage 'dist/*.test.js' 'dist/**/*.test.js'",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "metrics",
    "tokens",
    "validation"
  ],
  "author": "UluOps",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.*",
    "!dist/test-utils.*",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
